---
import {
  INTEREST_CHOICES,
  NOTIFICATION_CHOICES,
  PRICE_CHOICES,
  THEME_CHOICES,
  USAGE_CHOICES,
} from '../lib/pre-register-options';

const inputClass =
  'w-full rounded-xl border border-gray-200 px-4 py-3 text-gray-900 placeholder:text-gray-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/30';
const labelClass = 'block text-sm font-bold text-gray-900 mb-1.5';
const hintClass = 'text-xs text-gray-500 mt-1';
const groupBoxClass =
  'rounded-xl border border-gray-100 bg-gray-50/80 p-4 space-y-3';
const checkLabelClass = 'flex items-start gap-3 cursor-pointer text-sm text-gray-700';
const checkInputClass =
  'mt-1 h-4 w-4 shrink-0 rounded border-gray-300 text-emerald-600 focus:ring-emerald-500';
---

<section id="pre-register" class="py-16 md:py-24 bg-gray-50 scroll-mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <span
        class="inline-block px-4 py-1.5 bg-emerald-100 text-emerald-700 rounded-full text-sm font-medium mb-4"
      >
        事前お申し込み
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">事前お申し込みフォーム</h2>
      <p class="text-gray-600 text-lg max-w-2xl mx-auto">
        KiwiCo Japan にご関心をお寄せいただきありがとうございます。今後のサービス開始情報や先行案内をお届けするため、事前登録を受け付けています。1〜2分でご回答いただけます。
      </p>
    </div>

    <div class="max-w-[680px] mx-auto">
      <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-6 md:p-10">
        <form id="pre-register-form" class="relative space-y-8" novalidate>
          <p
            class="hidden rounded-lg bg-red-50 text-red-700 text-sm px-4 py-3"
            data-form-error
            role="alert"
          >
          </p>

          <input type="hidden" name="csrfToken" value="" />

          <div
            class="absolute w-px h-px overflow-hidden opacity-0 pointer-events-none"
            style="clip: rect(0, 0, 0, 0)"
            aria-hidden="true"
          >
            <input type="text" name="website" tabindex="-1" autocomplete="off" value="" />
          </div>

          <div>
            <label for="pre-email" class={labelClass}>
              メールアドレス <span class="text-red-500">*</span>
            </label>
            <input
              id="pre-email"
              name="email"
              type="email"
              autocomplete="email"
              class={inputClass}
              placeholder="example@email.com"
            />
            <p class="hidden text-sm text-red-600 mt-1" data-error-for="email"></p>
          </div>

          <div>
            <label for="pre-name" class={labelClass}>
              お名前 <span class="text-red-500">*</span>
            </label>
            <input id="pre-name" name="name" type="text" autocomplete="name" class={inputClass} />
            <p class="hidden text-sm text-red-600 mt-1" data-error-for="name"></p>
          </div>

          <div>
            <label for="pre-children" class={labelClass}>
              お子様の年齢 <span class="text-red-500">*</span>
            </label>
            <input
              id="pre-children"
              name="children_ages"
              type="text"
              class={inputClass}
              placeholder="例: 4歳、6歳"
            />
            <p class={hintClass}>対象となれば何人分でもOK🥝</p>
            <p class="hidden text-sm text-red-600 mt-1" data-error-for="children_ages"></p>
          </div>

          <fieldset class="space-y-2">
            <legend class={labelClass}>
              KiwiCoのどんなところに興味がありますか? <span class="text-red-500">*</span>
            </legend>
            <p class={hintClass}>複数選択可</p>
            <div class={groupBoxClass}>
              {
                INTEREST_CHOICES.map((label) => (
                  <label class={checkLabelClass}>
                    <input type="checkbox" name="interests" value={label} class={checkInputClass} />
                    <span>{label}</span>
                  </label>
                ))
              }
            </div>
            <div class="mt-3">
              <label for="pre-interest-other" class="text-sm font-medium text-gray-700"
                >その他の内容（該当する場合）</label
              >
              <input
                id="pre-interest-other"
                name="interest_other"
                type="text"
                class={`${inputClass} mt-1`}
              />
            </div>
            <p class="hidden text-sm text-red-600 mt-1" data-error-for="interests"></p>
            <p class="hidden text-sm text-red-600 mt-1" data-error-for="interest_other"></p>
          </fieldset>

          <fieldset class="space-y-2">
            <legend class={labelClass}>
              どのテーマだと関心を持てますか? <span class="text-red-500">*</span>
            </legend>
            <p class={hintClass}>複数選択可</p>
            <div class={groupBoxClass}>
              {
                THEME_CHOICES.map((label) => (
                  <label class={checkLabelClass}>
                    <input type="checkbox" name="themes" value={label} class={checkInputClass} />
                    <span>{label}</span>
                  </label>
                ))
              }
            </div>
            <div class="mt-3">
              <label for="pre-theme-other" class="text-sm font-medium text-gray-700"
                >その他の内容（該当する場合）</label
              >
              <input
                id="pre-theme-other"
                name="theme_other"
                type="text"
                class={`${inputClass} mt-1`}
              />
            </div>
            <p class="hidden text-sm text-red-600 mt-1" data-error-for="themes"></p>
            <p class="hidden text-sm text-red-600 mt-1" data-error-for="theme_other"></p>
          </fieldset>

          <fieldset class="space-y-2">
            <legend class={labelClass}>月額または1回あたりの価格として、どのくらいなら検討しやすいですか？</legend>
            <p class={hintClass}>任意・1つだけ選択</p>
            <div class={groupBoxClass}>
              {
                PRICE_CHOICES.map((label) => (
                  <label class={checkLabelClass}>
                    <input
                      type="radio"
                      name="price_range"
                      value={label}
                      class="mt-1 h-4 w-4 shrink-0 border-gray-300 text-emerald-600 focus:ring-emerald-500"
                    />
                    <span>{label}</span>
                  </label>
                ))
              }
            </div>
          </fieldset>

          <fieldset class="space-y-2">
            <legend class={labelClass}>今後、以下のご案内を受け取りますか？</legend>
            <p class={hintClass}>任意・複数選択可</p>
            <div class={groupBoxClass}>
              {
                NOTIFICATION_CHOICES.map((label) => (
                  <label class={checkLabelClass}>
                    <input type="checkbox" name="notifications" value={label} class={checkInputClass} />
                    <span>{label}</span>
                  </label>
                ))
              }
            </div>
          </fieldset>

          <fieldset class="space-y-2">
            <legend class={labelClass}>ご利用イメージに近いものを教えてください</legend>
            <p class={hintClass}>任意・1つだけ選択</p>
            <div class={groupBoxClass}>
              {
                USAGE_CHOICES.map((label) => (
                  <label class={checkLabelClass}>
                    <input
                      type="radio"
                      name="usage_image"
                      value={label}
                      class="mt-1 h-4 w-4 shrink-0 border-gray-300 text-emerald-600 focus:ring-emerald-500"
                    />
                    <span>{label}</span>
                  </label>
                ))
              }
            </div>
          </fieldset>

          <div>
            <label class={checkLabelClass}>
              <input id="pre-consent" name="consent" type="checkbox" value="yes" class={checkInputClass} />
              <span>
                <span class="text-red-500">*</span>
                同意します（ご回答いただいた情報は、KiwiCo Japan
                の事前案内およびサービス改善のために利用します）
              </span>
            </label>
            <p class="hidden text-sm text-red-600 mt-1" data-error-for="consent"></p>
          </div>

          <div class="pt-2">
            <button
              type="submit"
              data-submit-btn
              class="w-full inline-flex items-center justify-center gap-2 rounded-full bg-emerald-500 hover:bg-emerald-600 text-white font-bold py-4 px-8 shadow-lg shadow-emerald-500/25 transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
            >
              <span data-submit-label>送信する</span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  import '../scripts/pre-register-form.ts';
</script>
