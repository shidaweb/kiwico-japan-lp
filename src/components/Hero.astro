---
const formUrl = "https://forms.gle/3DC4hfCGngB2r6CU6";
---

<section class="relative bg-gradient-to-br from-emerald-50 via-white to-teal-50 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 lg:py-32">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Text Content -->
      <div class="text-center lg:text-left">
        <!-- Eyebrow -->
        <span class="inline-block px-4 py-1.5 bg-emerald-100 text-emerald-700 text-sm font-medium rounded-full mb-6">
          KiwiCo Japan Preview
        </span>
        
        <!-- Headline -->
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 leading-tight mb-6">
          世界中で人気の<span class="text-emerald-600">STEAM体験</span>を、<br class="hidden sm:block" />日本のご家庭に。
        </h1>
        
        <!-- Supporting Text -->
        <p class="text-lg md:text-xl text-gray-600 mb-8 max-w-xl mx-auto lg:mx-0">
          作って、試して、夢中になる。年齢に合わせた学びのキットが毎月届く、サブスクリプション型のSTEAM教育サービスです。
        </p>
        
        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a 
            href={formUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-8 py-4 bg-emerald-500 hover:bg-emerald-600 text-white font-bold rounded-full shadow-lg hover:shadow-xl transition-all duration-200 text-lg"
          >
            事前お申し込みはこちら
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a 
            href="#how-it-works"
            class="inline-flex items-center justify-center px-8 py-4 bg-white hover:bg-gray-50 text-gray-700 font-medium rounded-full border-2 border-gray-200 hover:border-gray-300 transition-all duration-200 text-lg"
          >
            サービスを見る
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
        </div>
      </div>
      
      <!-- Hero GIF Carousel -->
      <div class="relative lg:order-last" id="hero-gif-carousel">
        <div class="relative aspect-square rounded-3xl overflow-hidden shadow-2xl bg-white">
          <!-- Slide 1 -->
          <div class="hero-slide absolute inset-0 opacity-100 transition-opacity duration-700" data-index="0">
            <picture>
              <source srcset="/images/gifs/desktop/LAB1ACH-Hero.webp" type="image/webp" media="(min-width: 640px)" />
              <source srcset="/images/gifs/mobile/LAB1ACH-Hero.webp" type="image/webp" />
              <img
                src="/images/gifs/source/PDP-LAB1ACH-Product-Hero-GIF-2024-08-26_0377.gif"
                alt="アーチェリーキット — 自分で作った弓で的当て"
                class="w-full h-full object-cover gif-viewport"
                loading="eager"
                fetchpriority="high"
              />
            </picture>
          </div>

          <!-- Slide 2 -->
          <div class="hero-slide absolute inset-0 opacity-0 transition-opacity duration-700" data-index="1">
            <picture>
              <source srcset="/images/gifs/desktop/K2BOD-Hero.webp" type="image/webp" media="(min-width: 640px)" />
              <source srcset="/images/gifs/mobile/K2BOD-Hero.webp" type="image/webp" />
              <img
                src="/images/gifs/source/1000x1000-PDP-K2BOD-Product-Hero-GIF.gif"
                alt="からだの仕組みキット"
                class="w-full h-full object-cover gif-viewport"
                loading="lazy"
              />
            </picture>
          </div>

          <!-- Slide 3 -->
          <div class="hero-slide absolute inset-0 opacity-0 transition-opacity duration-700" data-index="2">
            <picture>
              <source srcset="/images/gifs/desktop/LAB1SPA-Hero.webp" type="image/webp" media="(min-width: 640px)" />
              <source srcset="/images/gifs/mobile/LAB1SPA-Hero.webp" type="image/webp" />
              <img
                src="/images/gifs/source/Store-PDP-LAB1SPA-Product-Hero-GIF-2024-09-11_Frame01.gif"
                alt="スピンアートマシン"
                class="w-full h-full object-cover gif-viewport"
                loading="lazy"
              />
            </picture>
          </div>

          <!-- Slide 4 -->
          <div class="hero-slide absolute inset-0 opacity-0 transition-opacity duration-700" data-index="3">
            <picture>
              <source srcset="/images/gifs/desktop/O2LAV-Hero.webp" type="image/webp" media="(min-width: 640px)" />
              <source srcset="/images/gifs/mobile/O2LAV-Hero.webp" type="image/webp" />
              <img
                src="/images/gifs/source/1000x1000-PDP-O2LAV-Product-Hero-GIF.gif"
                alt="バブルランプキット"
                class="w-full h-full object-cover gif-viewport"
                loading="lazy"
              />
            </picture>
          </div>

          <!-- Slide 5 -->
          <div class="hero-slide absolute inset-0 opacity-0 transition-opacity duration-700" data-index="4">
            <picture>
              <source srcset="/images/gifs/desktop/K2REP-Hero.webp" type="image/webp" media="(min-width: 640px)" />
              <source srcset="/images/gifs/mobile/K2REP-Hero.webp" type="image/webp" />
              <img
                src="/images/gifs/source/1000x1000-PDP-K2REP-Product-Hero-GIF.gif"
                alt="レプタイルキット"
                class="w-full h-full object-cover gif-viewport"
                loading="lazy"
              />
            </picture>
          </div>

          <!-- Slide Label -->
          <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/60 to-transparent p-4">
            <p id="hero-slide-label" class="text-white text-sm font-medium">アーチェリーキット</p>
          </div>
        </div>

        <!-- Dots -->
        <div class="flex justify-center gap-2 mt-4">
          <button class="w-2.5 h-2.5 rounded-full bg-emerald-500 carousel-dot" data-index="0"></button>
          <button class="w-2.5 h-2.5 rounded-full bg-gray-300 carousel-dot" data-index="1"></button>
          <button class="w-2.5 h-2.5 rounded-full bg-gray-300 carousel-dot" data-index="2"></button>
          <button class="w-2.5 h-2.5 rounded-full bg-gray-300 carousel-dot" data-index="3"></button>
          <button class="w-2.5 h-2.5 rounded-full bg-gray-300 carousel-dot" data-index="4"></button>
        </div>

        <!-- Decorative Elements -->
        <div class="pointer-events-none" aria-hidden="true">
          <div class="absolute -top-4 -right-4 w-24 h-24 bg-emerald-200 rounded-full opacity-50 blur-xl"></div>
          <div class="absolute -bottom-8 -left-8 w-32 h-32 bg-teal-200 rounded-full opacity-50 blur-xl"></div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Bottom Wave -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
      <path d="M0 120L60 105C120 90 240 60 360 45C480 30 600 30 720 37.5C840 45 960 60 1080 67.5C1200 75 1320 75 1380 75L1440 75V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="white"/>
    </svg>
  </div>
</section>
