---
const steps = [
  {
    number: "01",
    title: "年齢や興味に合ったキットを選ぶ",
    description: "お子さまの年齢や興味に合わせて、最適なキットをお選びいただけます。"
  },
  {
    number: "02",
    title: "届いたらすぐに取り組める",
    description: "必要なものはすべて揃っています。届いたその日から、すぐに楽しめます。"
  },
  {
    number: "03",
    title: "楽しみながら学びが広がる",
    description: "作る喜びと学ぶ喜びが一体に。好奇心が次の探究へとつながります。"
  }
];
---

<section id="how-it-works" class="py-16 md:py-24 bg-amber-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12 md:mb-16">
      <span class="inline-block px-3 py-1 bg-white text-amber-700 text-sm font-medium rounded-full mb-4">
        ご利用の流れ
      </span>
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        シンプルな3ステップ
      </h2>
      <p class="text-gray-600 text-lg max-w-2xl mx-auto">
        簡単に始められて、長く楽しめる。それがKiwiCoのスタイルです。
      </p>
    </div>
    
    <!-- Steps -->
    <div class="grid md:grid-cols-3 gap-8">
      {steps.map((step, index) => (
        <div class="relative">
          {/* Connector Line (hidden on mobile) */}
          {index < steps.length - 1 && (
            <div class="hidden md:block absolute top-12 left-full w-full h-0.5 bg-amber-200 -translate-x-1/2 z-0"></div>
          )}
          
          <div class="relative bg-white p-8 rounded-2xl shadow-sm z-10">
            <div class="inline-flex items-center justify-center w-12 h-12 bg-amber-500 text-white font-bold rounded-full mb-4">
              {step.number}
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">{step.title}</h3>
            <p class="text-gray-600 leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
