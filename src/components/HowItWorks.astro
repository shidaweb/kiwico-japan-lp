---
const steps = [
  {
    number: "01",
    title: "年齢や興味に合ったキットを選ぶ",
    description: "お子さまの年齢や興味に合わせて、最適なキットをお選びいただけます。"
  },
  {
    number: "02",
    title: "キットを受け取る",
    description: "必要なものはすべて揃っています。届いたその日から、すぐに楽しめます。"
  },
  {
    number: "03",
    title: "インストラクションに沿って、遊んで学ぶ",
    description: "作る楽しさと学ぶ喜びが一体に。好奇心が次の探究へとつながります。"
  }
];
---

<section id="how-it-works" class="py-16 md:py-24 bg-emerald-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12 md:mb-16">
      <span class="inline-block px-3 py-1 bg-white text-emerald-700 text-sm font-medium rounded-full mb-4">
        ご利用の流れ
      </span>
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        シンプルな3ステップ
      </h2>
      <p class="text-gray-600 text-lg max-w-2xl mx-auto">
        簡単に始められて、長く楽しめる。それがKiwiCoのスタイルです。
      </p>
    </div>
    
    <!-- Steps -->
    <div class="grid md:grid-cols-3 gap-8">
      {steps.map((step, index) => (
        <div class="relative">
          {/* Connector Line (hidden on mobile) */}
          {index < steps.length - 1 && (
            <div class="hidden md:block absolute top-12 left-full w-full h-0.5 bg-emerald-200 -translate-x-1/2 z-0"></div>
          )}
          
          <div class="relative bg-white p-8 rounded-2xl shadow-sm z-10">
            <!-- GIF Thumbnail -->
            {index === 0 && (
              <div class="aspect-video rounded-xl overflow-hidden bg-gray-100 mb-4">
                <picture>
                  <source srcset="/images/gifs/desktop/K2BOD-Detail.webp" type="image/webp" />
                  <img
                    src="/images/gifs/source/1000x1000-PDP-K2BOD-Product-Detail-GIF.gif"
                    alt="キットを選ぶ様子"
                    class="w-full h-full object-cover gif-viewport"
                    loading="lazy"
                  />
                </picture>
              </div>
            )}
            {index === 1 && (
              <div class="aspect-video rounded-xl overflow-hidden bg-gray-100 mb-4">
                <img
                  src="/images/gifs/source/kiwico-delivery-scene.png"
                  alt="キットがご自宅に届く様子"
                  class="w-full h-full object-cover gif-viewport"
                  loading="lazy"
                />
              </div>
            )}
            {index === 2 && (
              <div class="aspect-video rounded-xl overflow-hidden bg-gray-100 mb-4">
                <picture>
                  <source
                    srcset="/images/gifs/desktop/LAB1SPA-lifestyle.webp"
                    type="image/webp"
                  />
                  <img
                    src="/images/gifs/source/PDP-LAB1SPA-lifestyle-GIF.gif"
                    alt="子どもがキットで遊んで学ぶ様子"
                    class="w-full h-full object-cover gif-viewport"
                    loading="lazy"
                  />
                </picture>
              </div>
            )}
            <div class="inline-flex items-center justify-center w-12 h-12 bg-emerald-500 text-white font-bold rounded-full mb-4">
              {step.number}
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">{step.title}</h3>
            <p class="text-gray-600 leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
