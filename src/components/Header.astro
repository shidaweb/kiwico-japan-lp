---
const formAnchor = '#pre-register';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <svg class="w-8 h-8 text-emerald-500" viewBox="0 0 32 32" fill="currentColor">
          <circle cx="16" cy="16" r="14" fill="currentColor"/>
          <path d="M10 12c0-1.1.9-2 2-2h8c1.1 0 2 .9 2 2v8c0 1.1-.9 2-2 2h-8c-1.1 0-2-.9-2-2v-8z" fill="white"/>
          <circle cx="14" cy="15" r="1.5" fill="currentColor"/>
          <circle cx="18" cy="15" r="1.5" fill="currentColor"/>
          <path d="M13 19c0 0 1.5 2 3 2s3-2 3-2" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        </svg>
        <span class="text-xl font-bold text-gray-900">KiwiCo</span>
        <span class="text-sm font-medium text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded">Japan</span>
      </a>
      
      <!-- CTA Button -->
      <a
        href={formAnchor}
        class="inline-flex items-center justify-center px-5 py-2.5 bg-emerald-500 hover:bg-emerald-600 text-white font-bold rounded-full shadow-sm hover:shadow-md transition-all duration-200 text-sm"
      >
        事前お申し込み
        <svg class="ml-1.5 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16"></div>
