---
const testimonials = [
  {
    quote: "毎月届くのが楽しみで、届いた日は夢中で取り組んでいます。親が準備しなくていいのが本当に助かります。",
    author: "東京都 S.T.さん",
    detail: "6歳のお子さまのお母さま",
    rating: 5
  },
  {
    quote: "科学や工作に興味を持つきっかけになりました。説明書を読みながら自分で考える力がついてきたように感じます。",
    author: "大阪府 M.K.さん",
    detail: "8歳のお子さまのお父さま",
    rating: 5
  },
  {
    quote: "子どもの「なんで？」「どうして？」に答えてくれる教材。一緒に取り組む時間が親子の大切なコミュニケーションになっています。",
    author: "神奈川県 A.Y.さん",
    detail: "5歳と7歳のお子さまのお母さま",
    rating: 5
  }
];

---

<section class="py-16 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <span class="inline-block px-3 py-1 bg-emerald-100 text-emerald-700 text-sm font-medium rounded-full mb-4">
        お客様の声
      </span>
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        国内でお使いのご家族からの感想
      </h2>
      <p class="text-gray-600 text-lg max-w-2xl mx-auto">
        世界中の保護者様から高い評価をいただいています。
      </p>
    </div>
    
    <!-- Testimonials Grid -->
    <div class="grid md:grid-cols-3 gap-6 md:gap-8">
      {testimonials.map((testimonial) => (
        <div class="bg-gray-50 p-6 md:p-8 rounded-2xl">
          <!-- Rating Stars -->
          <div class="flex gap-0.5 mb-4">
            {[...Array(testimonial.rating)].map(() => (
              <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          
          <!-- Quote -->
          <blockquote class="text-gray-700 leading-relaxed mb-6">
            "{testimonial.quote}"
          </blockquote>
          
          <!-- Author -->
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-emerald-100 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <div>
              <div class="font-medium text-gray-900 text-sm">{testimonial.author}</div>
              <div class="text-gray-500 text-xs">{testimonial.detail}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
