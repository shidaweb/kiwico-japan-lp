---
const benefits = [
  {
    icon: "✨",
    title: "夢中になる体験",
    description: "手を動かしながら学ぶことで、子どもの好奇心に火がつきます。遊びの延長で、自然と探究心が育ちます。"
  },
  {
    icon: "🎯",
    title: "年齢に合わせた設計",
    description: "発達段階に合った難易度とテーマで設計。無理なく楽しめて、達成感を得られる体験をお届けします。"
  },
  {
    icon: "📦",
    title: "親の準備が少ない",
    description: "必要な材料はすべてキットに含まれています。届いたらすぐに始められるから、忙しいご家庭でも安心。"
  }
];
---

<section class="py-16 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12 md:mb-16">
      <span class="inline-block px-3 py-1 bg-amber-100 text-amber-700 text-sm font-medium rounded-full mb-4">
        選ばれる理由
      </span>
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        なぜKiwiCoが選ばれるのか
      </h2>
      <p class="text-gray-600 text-lg max-w-2xl mx-auto">
        世界中の家庭で愛されているSTEAM教育キット。その理由をご紹介します。
      </p>
    </div>
    
    <!-- Benefits Grid -->
    <div class="grid md:grid-cols-3 gap-8">
      {benefits.map((benefit) => (
        <div class="bg-gradient-to-br from-gray-50 to-white p-8 rounded-2xl shadow-sm hover:shadow-md transition-shadow duration-200 border border-gray-100">
          <div class="text-4xl mb-4">{benefit.icon}</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">{benefit.title}</h3>
          <p class="text-gray-600 leading-relaxed">{benefit.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
