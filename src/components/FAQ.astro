---
const faqs = [
  {
    question: "何歳向けですか？",
    answer: "KiwiCoは、0歳から大人まで幅広い年齢層に対応したキットをご用意しています。日本では、まず幼児〜小学生向けのキットからスタートする予定です。"
  },
  {
    question: "日本語の案内はありますか？",
    answer: "はい、日本向けサービスでは、日本語のガイドや説明書をご用意する予定です。お子さまと一緒に安心して取り組んでいただけます。"
  },
  {
    question: "いつ始まりますか？",
    answer: "現在、日本でのサービス開始に向けて準備を進めています。事前お申し込みいただいた方には、最新情報を優先的にお届けします。"
  },
  {
    question: "どんな内容が届きますか？",
    answer: "科学実験、工作、エンジニアリング、アートなど、STEAMをテーマにした多彩なキットをお届けします。毎回異なるテーマで、新しい発見があります。"
  },
  {
    question: "まず何をすればいいですか？",
    answer: "まずは事前お申し込みフォームにご登録ください。サービス開始時期や詳細が決まり次第、ご案内をお送りいたします。"
  }
];
---

<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <span class="inline-block px-3 py-1 bg-amber-100 text-amber-700 text-sm font-medium rounded-full mb-4">
        よくあるご質問
      </span>
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        FAQ
      </h2>
      <p class="text-gray-600 text-lg">
        お寄せいただくご質問にお答えします。
      </p>
    </div>
    
    <!-- FAQ Items -->
    <div class="space-y-4">
      {faqs.map((faq) => (
        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
            <span class="font-bold text-gray-900 text-left pr-4">{faq.question}</span>
            <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-amber-100 text-amber-600 group-open:rotate-180 transition-transform duration-200">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </span>
          </summary>
          <div class="px-6 pb-6">
            <p class="text-gray-600 leading-relaxed">{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
