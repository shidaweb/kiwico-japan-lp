---
const mediaLogos = [
  { name: "The New York Times", abbr: "NYT" },
  { name: "Forbes", abbr: "Forbes" },
  { name: "Parents Magazine", abbr: "Parents" },
  { name: "Good Housekeeping", abbr: "GH" },
  { name: "Today Show", abbr: "TODAY" }
];
---

<section class="py-10 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <p class="text-center text-gray-500 text-sm mb-6">メディア掲載実績</p>
    
    <div class="flex flex-wrap items-center justify-center gap-6 md:gap-10">
      {mediaLogos.map((media) => (
        <div class="flex items-center justify-center px-4 py-2 grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-200">
          <span class="text-lg md:text-xl font-serif font-bold text-gray-700">{media.abbr}</span>
        </div>
      ))}
    </div>
  </div>
</section>
