---
const products = [
  {
    id: "create",
    title: "つくる",
    subtitle: "Create",
    description:
      "自分の手で形にする喜び。工作やものづくりを通じて、創造力と自信を育みます。",
  },
  {
    id: "experiment",
    title: "実験する",
    subtitle: "Experiment",
    description:
      "なぜ？どうして？を自分で確かめる。科学の面白さを体感できる実験キット。",
  },
  {
    id: "discover",
    title: "しくみを学ぶ",
    subtitle: "Discover",
    description:
      "身の回りのしくみを理解する。エンジニアリングの基礎を遊びながら学びます。",
  },
];
---

<section class="py-16 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12 md:mb-16">
      <span class="inline-block px-3 py-1 bg-emerald-100 text-emerald-700 text-sm font-medium rounded-full mb-4">
        学びのテーマ
      </span>
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        多彩な体験で好奇心を刺激
      </h2>
      <p class="text-gray-600 text-lg max-w-2xl mx-auto">
        さまざまなテーマのキットで、お子さまの「やってみたい」を応援します。
      </p>
    </div>
    
    <!-- Product Cards -->
    <div class="grid md:grid-cols-3 gap-8">
      {products.map((product) => (
        <div class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300 border border-gray-100">
          <div class="relative overflow-hidden aspect-[4/3]">
            {product.id === "create" && (
              <picture>
                <source
                  srcset="/images/gifs/desktop/LAB1ACH-Detail-0429.webp"
                  type="image/webp"
                />
                <img
                  src="/images/gifs/source/PDP-LAB1ACH-Product-Detail-GIF-2024-08-26_0429_v2.gif"
                  alt="つくるキットイメージ"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300 gif-viewport"
                  loading="lazy"
                />
              </picture>
            )}
            {product.id === "experiment" && (
              <picture>
                <source srcset="/images/gifs/desktop/O2LAV-Hero.webp" type="image/webp" />
                <img
                  src="/images/gifs/source/1000x1000-PDP-O2LAV-Product-Hero-GIF.gif"
                  alt="実験するキットイメージ"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300 gif-viewport"
                  loading="lazy"
                />
              </picture>
            )}
            {product.id === "discover" && (
              <picture>
                <source srcset="/images/gifs/desktop/O2SWE-Detail.webp" type="image/webp" />
                <img
                  src="/images/gifs/source/1000x1000-PDP-O2SWE-Product-Detail-GIF.gif"
                  alt="しくみを学ぶキットイメージ"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300 gif-viewport"
                  loading="lazy"
                />
              </picture>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-black/30 to透明"></div>
          </div>
          <div class="p-6">
            <div class="flex items-baseline gap-2 mb-2">
              <h3 class="text-xl font-bold text-gray-900">{product.title}</h3>
              <span class="text-sm text-emerald-600 font-medium">{product.subtitle}</span>
            </div>
            <p class="text-gray-600 leading-relaxed">{product.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
