# Cloudflare Pages / Workers + Astro 6
# -------------------------------------
# ローカル（`npm run dev`）: プロジェクト直下に `.dev.vars` を置く（Wrangler が読み込みます）。
# 任意で `.env.local` に同じキーを複製しても構いません（import.meta.env / process フォールバック用）。
#
# 本番（Cloudflare Dashboard）:
#   Workers & Pages → 該当プロジェクト → Settings → Variables and secrets
#   次の 4 つを **Encrypt（Secret）** 推奨で登録:
#     SUPABASE_URL（平文でも可）
#     SUPABASE_SERVICE_ROLE_KEY
#     RESEND_API_KEY
#     CSRF_SECRET

SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
CSRF_SECRET=
